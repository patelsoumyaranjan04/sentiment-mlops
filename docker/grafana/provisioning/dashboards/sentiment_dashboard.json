{
  "title": "Sentiment API Monitoring",
  "uid": "sentiment-mlops",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "gridPos": { "x": 0, "y": 0, "w": 3, "h": 4 },
      "title": "Total Predictions",
      "targets": [{ "expr": "sum(sentiment_predictions_total)", "legendFormat": "Total" }],
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 2, "type": "stat", "gridPos": { "x": 3, "y": 0, "w": 3, "h": 4 },
      "title": "Positive Predictions",
      "targets": [{ "expr": "sentiment_predictions_total{sentiment='positive'}", "legendFormat": "Positive" }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "green", "mode": "fixed" } } }
    },
    {
      "id": 3, "type": "stat", "gridPos": { "x": 6, "y": 0, "w": 3, "h": 4 },
      "title": "Negative Predictions",
      "targets": [{ "expr": "sentiment_predictions_total{sentiment='negative'}", "legendFormat": "Negative" }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" } } }
    },
    {
      "id": 4, "type": "gauge", "gridPos": { "x": 9, "y": 0, "w": 3, "h": 4 },
      "title": "Positive Ratio",
      "targets": [{ "expr": "sentiment_positive_ratio * 100", "legendFormat": "%" }],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red",    "value": 0  },
              { "color": "yellow", "value": 10 },
              { "color": "green",  "value": 30 },
              { "color": "yellow", "value": 70 },
              { "color": "red",    "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 5, "type": "stat", "gridPos": { "x": 12, "y": 0, "w": 3, "h": 4 },
      "title": "Model Loaded",
      "targets": [{ "expr": "sentiment_model_loaded", "legendFormat": "Status" }],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 6, "type": "timeseries", "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "title": "Prediction Rate (req/s)",
      "targets": [
        { "expr": "rate(sentiment_predictions_total{sentiment='positive'}[1m])", "legendFormat": "Positive/s" },
        { "expr": "rate(sentiment_predictions_total{sentiment='negative'}[1m])", "legendFormat": "Negative/s" }
      ]
    },
    {
      "id": 7, "type": "timeseries", "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "title": "Inference Latency (p50 / p95 / p99)",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(sentiment_prediction_latency_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(sentiment_prediction_latency_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(sentiment_prediction_latency_seconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 8, "type": "timeseries", "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "title": "HTTP Request Rate",
      "targets": [
        { "expr": "rate(http_requests_total{job='sentiment_api'}[1m])", "legendFormat": "{{method}} {{handler}} {{status}}" }
      ]
    },
    {
      "id": 9, "type": "heatmap", "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "title": "Input Review Length Distribution",
      "targets": [{ "expr": "rate(sentiment_input_length_words_bucket[5m])", "legendFormat": "{{le}}" }]
    },
    {
      "id": 10, "type": "stat", "gridPos": { "x": 0, "y": 20, "w": 4, "h": 4 },
      "title": "🚨 Drift Detected",
      "targets": [{ "expr": "sentiment_drift_detected", "legendFormat": "Drift" }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "NO DRIFT", "color": "green" },
              "1": { "text": "DRIFT DETECTED", "color": "red" }
            }}
          ]
        }
      }
    },
    {
      "id": 11, "type": "stat", "gridPos": { "x": 4, "y": 20, "w": 4, "h": 4 },
      "title": "KS Statistic",
      "description": "KS test statistic — higher means more drift (0=none, 1=complete drift)",
      "targets": [{ "expr": "sentiment_drift_ks_statistic", "legendFormat": "KS" }],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "decimals": 3,
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0   },
              { "color": "yellow", "value": 0.1 },
              { "color": "red",    "value": 0.3 }
            ]
          }
        }
      }
    },
    {
      "id": 12, "type": "stat", "gridPos": { "x": 8, "y": 20, "w": 4, "h": 4 },
      "title": "KS p-value",
      "description": "p-value < 0.05 indicates statistically significant drift",
      "targets": [{ "expr": "sentiment_drift_p_value", "legendFormat": "p-value" }],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",  "value": 0    },
              { "color": "yellow", "value": 0.01 },
              { "color": "green",    "value": 0.05 }
            ]
          }
        }
      }
    },
    {
      "id": 13, "type": "stat", "gridPos": { "x": 12, "y": 20, "w": 4, "h": 4 },
      "title": "Mean Length Shift",
      "description": "Difference between incoming text length and training baseline",
      "targets": [{ "expr": "sentiment_drift_mean_shift", "legendFormat": "Shift" }],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "decimals": 1, "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": -999 },
              { "color": "yellow", "value": -10  },
              { "color": "green",  "value": -5   }
            ]
          }
        }
      }
    },
    {
      "id": 14, "type": "timeseries", "gridPos": { "x": 16, "y": 20, "w": 8, "h": 4 },
      "title": "Drift Detection Over Time",
      "targets": [
        { "expr": "sentiment_drift_detected",    "legendFormat": "Drift Detected (0/1)" },
        { "expr": "sentiment_drift_ks_statistic","legendFormat": "KS Statistic" }
      ]
    },
    {
      "id": 15, "type": "timeseries", "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "title": "Input Length: Window Mean vs Baseline",
      "description": "Compares current rolling window mean to training baseline",
      "targets": [
        { "expr": "sentiment_drift_window_mean",   "legendFormat": "Current Window Mean" },
        { "expr": "sentiment_drift_baseline_mean", "legendFormat": "Training Baseline Mean" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 16, "type": "timeseries", "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "title": "Error Rate",
      "description": "Alert fires when error rate exceeds 5%",
      "targets": [
        {
          "expr": "rate(http_requests_total{job='sentiment_api', status=~'5..'}[5m]) / rate(http_requests_total{job='sentiment_api'}[5m])",
          "legendFormat": "Error Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0    },
              { "color": "yellow", "value": 0.02 },
              { "color": "red",    "value": 0.05 }
            ]
          }
        }
      }
    }
  ]
}
